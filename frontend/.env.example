# VIGÍA Frontend — Variables de entorno (copia a .env.local y rellena los valores)
# NUNCA commitear .env.local

# URL del backend (por defecto: localhost:8000)
VITE_API_URL=http://localhost:8000

# API key para endpoints de escritura — debe coincidir con VIGIA_API_KEY del backend
# Generar con: openssl rand -hex 32
VITE_API_KEY=
