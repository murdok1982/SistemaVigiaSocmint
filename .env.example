# ─────────────────────────────────────────────────────────────────────
# VIGÍA Military System - Environment Configuration
# ─────────────────────────────────────────────────────────────────────

# Application
VIGIA_ENV=production  # development | staging | production
VIGIA_LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://vigia:CHANGE_ME@db:5432/vigia_db

# Redis (Cache & Rate Limiting)
REDIS_URL=redis://:CHANGE_ME@redis:6379

# Security - JWT
JWT_SECRET_KEY=CHANGE_ME_WITH_64_CHAR_SECURE_KEY_GENERATE_WITH_openssl_rand_-hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Security - Encryption
VIGIA_MASTER_KEY=CHANGE_ME_WITH_32_CHAR_SECURE_KEY
VIGIA_HMAC_KEY=CHANGE_ME_WITH_ANOTHER_32_CHAR_KEY
VIGIA_HASH_SALT=CHANGE_ME_WITH_UNIQUE_SALT

# Security - API Keys
VIGIA_API_KEY=CHANGE_ME_WITH_SECURE_API_KEY_FOR_WRITES

# CORS
VIGIA_ALLOWED_ORIGINS=http://localhost:3000,https://vigia.gov.int

# Social Media APIs (Optional - configure as needed)
TWITTER_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
TELEGRAM_BOT_TOKEN=
META_ACCESS_TOKEN=
TIKTOK_ACCESS_TOKEN=
YOUTUBE_API_KEY=

# SIEM Integration
SIEM_TYPE=splunk  # splunk | elk | qradar | arcsight
SIEM_HOST=localhost
SIEM_PORT=9997
SIEM_API_ENDPOINT=https://localhost:8088/services/collector
SIEM_API_TOKEN=
SIEM_USE_TLS=false

# STIX/TAXII
TAXII_SERVER_URL=https://taxii.gov.int/api/v2
TAXII_API_KEY=
EUROPOL_API_ENDPOINT=https://api.europol.europa.eu/siena/v1/alerts
EUROPOL_API_KEY=

# Honeypot / Dark Web (Optional)
DARKWEB_MONITORING_ENABLED=false
HONEYPOT_API_ENDPOINT=

# Notification Settings
SMTP_HOST=smtp.gov.int
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_NOTIFICATION_EMAIL=security-team@gov.int

# MFA (Multi-Factor Authentication)
MFA_ISSUER=VIGÍA System
MFA_ENABLED=true

# Performance
WORKERS=4
MAX_CONNECTIONS=1000
REQUEST_TIMEOUT=30

# Feature Flags
ENABLE_MAP_VIEW=true
ENABLE_NETWORK_GRAPHS=true
ENABLE_REPORT_GENERATOR=true
ENABLE_MOBILE_SYNC=true
ENABLE_STIX_EXPORT=true
ENABLE_SIEM_INTEGRATION=true
