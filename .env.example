# VIGÍA — Variables de entorno (copia a .env y rellena los valores)
# NUNCA commitear el archivo .env

# ── API Keys de plataformas (obtener a través del organismo) ──────────────────
TWITTER_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
META_API_TOKEN=

# ── Base de datos ─────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./vigia.db

# ── Configuración del servidor ────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO

# ── Seguridad ─────────────────────────────────────────────────────────────────
# API key para endpoints de escritura (POST). Generar con: openssl rand -hex 32
# Si no se configura, los endpoints quedan sin protección (solo para desarrollo local).
VIGIA_API_KEY=

# Clave para firma HMAC del audit log (generar con: openssl rand -hex 32)
AUDIT_HMAC_KEY=

# Entorno: "production" deshabilita /docs y activa restricciones adicionales
VIGIA_ENV=development

# Orígenes CORS permitidos (separados por coma). En producción, lista explícita.
VIGIA_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Retención de datos (días) ─────────────────────────────────────────────────
DATA_RETENTION_DAYS=90
